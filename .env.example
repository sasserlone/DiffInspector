# ──────────────────────────────────────────────
# DiffInspector – Umgebungsvariablen
# ──────────────────────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an.
# .env ist in .gitignore – wird nicht committed!

# Für DeepSeek / OpenAI-kompatible APIs:
CRA_API_KEY="dein-api-key-hier"
# Alternative Names, die ebenfalls erkannt werden:
# DEEPSEEK_API_KEY="..."
# OPENAI_API_KEY="..."

# Für Ollama (lokal):
# CRA_OLLAMA_BASE_URL="http://localhost:11434"
# CRA_OLLAMA_MODEL="codellama:7b"
